# Local development env for the web app. Copy to `.env.local` and fill in.
#
# `vite dev` reads this file. For production see:
#   - .env.production.example  (build-time, public VITE_* values)
#   - .dev.vars.example         (Worker runtime secrets)
#   - ../DEPLOYMENT.md          (full runbook + variable matrix)

# --- Convex (client, build-time) ----------------------------------------------
# Dev deployment name and URL (from `npx convex dev` / the Convex dashboard).
CONVEX_DEPLOYMENT=
# Convex deployment URL (required). Inlined into the browser bundle.
VITE_CONVEX_URL=

# --- WorkOS (client, build-time) ----------------------------------------------
# WorkOS client id for the same environment as the Convex deployment
# (`npx convex env get WORKOS_CLIENT_ID` from ../).
VITE_WORKOS_CLIENT_ID=
# Your WorkOS Custom Authentication Domain in production; api.workos.com in dev.
VITE_WORKOS_API_HOSTNAME=api.workos.com

# --- WorkOS (server, runtime) -------------------------------------------------
# Read by the AuthKit server middleware via process.env. In production these are
# Worker secrets (wrangler secret put); locally they live here / in .dev.vars.
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
# 32+ char random string. Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=
# Must match a redirect URI registered in the WorkOS dashboard.
WORKOS_REDIRECT_URI=http://localhost:3000/api/auth/callback
