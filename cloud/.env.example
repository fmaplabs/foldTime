# Local Convex config used by the CLI (`npx convex dev`). Copy to `.env.local`.
#
# IMPORTANT: The Convex FUNCTIONS read their env from the DEPLOYMENT, not from
# this file. Set those with `npx convex env set <NAME> <value>` (add --prod for
# production). The deployment requires (see convex/convex.config.ts):
#   WORKOS_CLIENT_ID, WORKOS_API_KEY, WORKOS_ENVIRONMENT_ID, WORKOS_WEBHOOK_SECRET
# See DEPLOYMENT.md for the production setup.

# Deployment used by `npx convex dev` (from the Convex dashboard).
CONVEX_DEPLOYMENT=

# Convenience URLs for the dev deployment.
CONVEX_URL=
CONVEX_SITE_URL=
